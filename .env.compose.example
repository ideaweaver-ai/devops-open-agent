# Docker Compose public URLs (used for remote/AWS deployments)
# Copy to project root as .env before: docker compose up -d --build
#
# Local development (defaults if unset):
#   PUBLIC_API_BASE_URL=http://localhost:8000
#   PUBLIC_APP_URL=http://localhost:3000
#
# AWS / remote example:
#   PUBLIC_API_BASE_URL=http://<YOUR_IP_OR_DOMAIN>:8000
#   PUBLIC_APP_URL=http://<YOUR_IP_OR_DOMAIN>:3000

PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_APP_URL=http://localhost:3000
