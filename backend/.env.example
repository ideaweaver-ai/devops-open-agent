APP_ENV=development

# LLM provider: openai | anthropic | ollama | openrouter | gemini
LLM_PROVIDER=ollama

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local Ollama (use host.docker.internal:11434 when backend runs in Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

# AWS (optional — uses default credential chain: env vars, ~/.aws, IAM role)
# For Cloud Cost Detector dollar estimates, also grant: ce:GetCostAndUsage
# Do NOT leave AWS_PROFILE= blank — omit the line or set a real profile name.
# AWS_PROFILE=default
AWS_DEFAULT_REGION=us-west-2

KUBECONFIG_PATH=

# Inside Docker Compose, kubeconfig is mounted at /home/kube/.kube/config
# Leave KUBECONFIG_PATH empty locally, or set the container path above when overriding.

# Rewrite localhost API URLs when backend runs in Docker (Kind/minikube)
KUBE_API_HOST_REWRITE=host.docker.internal

# SQLite store for investigation history
DATABASE_PATH=data/investigations.db

# PostgreSQL for user authentication (use postgres service name in Docker Compose)
POSTGRES_URL=postgresql+asyncpg://kda:kda@postgres:5432/kda
JWT_SECRET=
JWT_EXPIRE_MINUTES=10080

# Default admin account (created automatically on startup if missing)
# DEFAULT_ADMIN_EMAIL stores the login username (default: admin)
# Copy this file to backend/.env and set secrets there — backend/.env is gitignored.
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin
DEFAULT_ADMIN_PASSWORD=

LOG_LEVEL=INFO
LLM_TIMEOUT=180

# GitHub PR Reviewer (Phase 1: personal access token)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_INSTALLATION_ID=

# Performance Debugging (SSH into Linux hosts — passwordless auth required)
# Configure SSH keys / agent on the host running the backend BEFORE using this agent.
# Docker Compose mounts ${HOME}/.ssh into the backend container as /root/.ssh (read-only).
# Prefer hostname or user@host targets. No SSH credentials are configured in this file.

# LLM-as-a-Judge (optional — uses a second AI to verify the primary diagnosis)
# Set a different provider/model to avoid self-confirmation bias.
# Falls back to the primary LLM_PROVIDER / model when empty.
# Reuses the same API keys — only provider and model are separate.
JUDGE_LLM_PROVIDER=
JUDGE_OPENAI_MODEL=
JUDGE_ANTHROPIC_MODEL=
JUDGE_OPENROUTER_MODEL=
JUDGE_GEMINI_MODEL=
JUDGE_OLLAMA_MODEL=

# Security Scanning (Trivy is bundled in the Docker image — no config needed)
# Trivy scans container images and Kubernetes clusters for vulnerabilities/misconfigs.
# K8s cluster scans reuse the same KUBECONFIG_PATH / mounted kubeconfig as the K8s agent.

# Comma-separated browser origins allowed to call the API (remote deploys)
# Example: CORS_ORIGINS=http://<YOUR_IP_OR_DOMAIN>:3000,http://localhost:3000
CORS_ORIGINS=

# Slack notifications (optional instance-level defaults for webhooks/GitHub events)
SLACK_BOT_TOKEN=
SLACK_INSTANCE_WEBHOOK_URL=
# Minimum minutes between Slack alerts per user (default 60 — reduces alert fatigue)
SLACK_NOTIFICATION_COOLDOWN_MINUTES=60

# PagerDuty notifications (optional instance-level routing key for GitHub webhook events)
PAGERDUTY_INSTANCE_ROUTING_KEY=
# Minimum minutes between PagerDuty alerts per user (default 60 — reduces alert fatigue)
PAGERDUTY_NOTIFICATION_COOLDOWN_MINUTES=60

# Microsoft Teams notifications (optional — see Integrations)
TEAMS_INSTANCE_WEBHOOK_URL=
TEAMS_NOTIFICATION_COOLDOWN_MINUTES=60

# Qdrant vector database / RAG (optional — see Integrations)
# In Docker Compose, use the service name: http://qdrant:6333
QDRANT_INSTANCE_URL=
QDRANT_INSTANCE_API_KEY=
QDRANT_COLLECTION=devops_open_agent_investigations
# Embedding provider for RAG: openai | gemini | ollama (defaults to LLM_PROVIDER when it supports embeddings)
RAG_EMBEDDING_PROVIDER=
# Embedding model override (defaults: openai=text-embedding-3-small, gemini=text-embedding-004, ollama=nomic-embed-text)
RAG_EMBEDDING_MODEL=
# Max number of past investigations retrieved for RAG context
RAG_MAX_RESULTS=4

# MCP server (optional instance-level defaults for shared MCP endpoint)
MCP_INSTANCE_SERVER_URL=
MCP_INSTANCE_API_KEY=
# Comma-separated MCP URLs or host patterns allowed for all users (optional security)
# MCP_ALLOWED_SERVER_URLS=https://api.githubcopilot.com/mcp/,api.githubcopilot.com

PUBLIC_APP_URL=http://localhost:3000

# Observability evidence for investigations (optional instance-level defaults)
# Configure per-user under Integrations → Prometheus / Grafana in the UI.
PROMETHEUS_INSTANCE_URL=
PROMETHEUS_INSTANCE_BEARER_TOKEN=
PROMETHEUS_INSTANCE_BASIC_AUTH_USER=
PROMETHEUS_INSTANCE_BASIC_AUTH_PASSWORD=
GRAFANA_INSTANCE_URL=
GRAFANA_INSTANCE_API_TOKEN=

